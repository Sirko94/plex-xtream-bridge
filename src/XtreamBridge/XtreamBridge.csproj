<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>XtreamBridge</RootNamespace>
    <AssemblyName>XtreamBridge</AssemblyName>
    <UserSecretsId>xtream-bridge-secrets</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <!-- No Jellyfin/Emby dependencies — pure .NET 8 -->
    <PackageReference Include="Microsoft.Extensions.Http" Version="8.0.1" />
    <!-- Newtonsoft.Json kept for robust edge-case handling (StringBool, SingularToList, Base64 converters) -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Serilog.AspNetCore" Version="8.0.3" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
  </ItemGroup>

  <!-- wwwroot is automatically included by Microsoft.NET.Sdk.Web -->

</Project>

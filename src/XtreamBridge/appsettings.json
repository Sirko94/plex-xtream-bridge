{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },

  "Paths": {
    "Config": "/config",
    "Output": "/output"
  },

  "Server": {
    "BaseUrl": "",
    "Username": "",
    "Password": ""
  },

  "Bridge": {
    "PublicBaseUrl": "http://localhost:8080",
    "DeviceName": "XtreamBridge",
    "TunerCount": 6,
    "DeviceId": "",
    "UserAgent": "",
    "EnableLiveTv": true,
    "EnableStrmGeneration": true
  },

  "Sync": {
    "ScheduleType": "Interval",
    "RefreshIntervalHours": 6,
    "DailyHour": 3,
    "DailyMinute": 0,
    "LiveCategoryFilter": [],
    "VodCategoryFilter": [],
    "SeriesCategoryFilter": [],
    "GenerateNfoFiles": true,
    "LiveStreamExtension": "ts",
    "IncludeAdultChannels": false,
    "EnableChannelNameCleaning": true,
    "ChannelRemoveTerms": "",
    "ChannelOverrides": "",
    "SyncParallelism": 10,
    "RequestDelayMs": 50,
    "MaxRetries": 3,
    "RetryDelayMs": 1000,
    "CleanupOrphans": true,
    "OrphanSafetyThreshold": 0.20,
    "EnableSnapshotSync": true,
    "EnableMetadataLookup": false,
    "TmdbApiKey": ""
  },

  "AllowedHosts": "*"
}
